# ============================================================
# ASSISTANT SAFETY + COMMAND EXECUTION
# ============================================================

# Hard block unsafe commands (rm, sudo, docker, kubectl, etc.)
PLAYGROUND_ALLOW_UNSAFE_COMMANDS=false

# Maximum command runtime (matches policy.json)
ASSISTANT_MAX_TIMEOUT_SECONDS=300

# Path to audit log inside each project
ASSISTANT_AUDIT_LOG_FILENAME=assistant-audit.log

# ============================================================
# PYTHON RUNTIME
# ============================================================

# Ensures Python prints immediately (no buffering)
PYTHONUNBUFFERED=1

# Allow Python subprocesses to run inside assistant
ASSISTANT_ENABLE_PYTHON_TOOLS=true

# ============================================================
# GIT + REPO ANALYZER
# ============================================================

# Allow git clone inside assistant actions
ASSISTANT_ENABLE_GIT_CLONE=true

# Allow repo analyzer + repo UI builder
ASSISTANT_ENABLE_REPO_ANALYZER=true
ASSISTANT_ENABLE_REPO_UI=true

# ============================================================
# USB EXPORT
# ============================================================

# Allow listing USB drives
ASSISTANT_ENABLE_USB_LIST=true

# Allow exporting project folders to USB
ASSISTANT_ENABLE_USB_EXPORT=true

# ============================================================
# REDACTION + LOGGING
# ============================================================

# Keys to redact in logs (comma-separated)
ASSISTANT_REDACT_KEYS=password,secret,token,api_key,auth,bearer,private_key

# ============================================================
# DEBOUNCE / RATE LIMITING
# ============================================================

# Prevent accidental double-runs
ASSISTANT_DEBOUNCE_SECONDS=1.0
